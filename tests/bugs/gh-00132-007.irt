--TEST--
GH-132: RLOAD/RSTORE rsp
--TARGET--
x86_64
--ARGS--
-S
--CODE--
{
	uintptr_t fn = func free(uintptr_t): void;
	uintptr_t c_0 = 0xffff;

	l_1 = START(l_99);

	uintptr_t d_2, l_2 = RLOAD(l_1, 4);
	uintptr_t d_3 = COPY(d_2, 1);

	l_4 = STORE(l_2, d_3, c_0);

	l_5 = CALL/1(l_4, fn, d_3);

	l_99 = RETURN(l_5);
}
--EXPECT--
test:
	subq $8, %rsp
	movq %rsp, %rdi
	movq $0xffff, (%rdi)
	callq free
	addq $8, %rsp
	retq

