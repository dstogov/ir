--TEST--
SEGV in ir_find_aliasing_vload_i on undefined variable during folding
--ARGS--
--save
--CODE--
func test(): int32_t
{
	uintptr_t c_1 = 0;
	int32_t c_4 = 0;
	l_1 = START(l_8);
	int32_t d_2 = VAR(l_1, "x");
	l_3 = VSTORE(l_1, d_2, c_5);
	int32_t d_4, l_4 = VLOAD(l_3, d_2);
	l_8 = RETURN(l_4, d_4);
}
--EXPECT--
ERROR: Undefined variable `c_5`

exit code = 2
