--TEST--
014: FOLD: AND(SHR(X, C), MASK) redundant mask with wide shift count
--ARGS--
-O2 --save
--CODE--
{
	uintptr_t c_1 = 0;
	bool c_2 = 0;
	bool c_3 = 1;
	uint32_t c_4 = 34;
	uint32_t c_5 = 1073741823;
	l_1 = START(l_7);
	uint32_t d_2 = PARAM(l_1, "a", 1);
	uint32_t d_3 = SHR(d_2, c_4);
	uint32_t d_4 = AND(d_3, c_5);
	l_7 = RETURN(l_1, d_4);
}
--EXPECT--
{
	uintptr_t c_1 = 0;
	bool c_2 = 0;
	bool c_3 = 1;
	uint32_t c_4 = 34;
	l_1 = START(l_4);
	uint32_t d_2 = PARAM(l_1, "a", 1);
	uint32_t d_3 = SHR(d_2, c_4);
	l_4 = RETURN(l_1, d_3);
}
